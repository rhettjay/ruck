{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "version": 3,
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "transient_prompt": {
            "background": "transparent",
            "foreground": "#ffffff",
            "template": "{{ .Shell }}> "
          }
        },
        {
          "secondary_prompt": {
            "background": "transparent",
            "foreground": "#ffffff",
            "template": "{{ .Shell }} "
          }
        },
        {
          "type": "kubectl",
          "style": "plain",
          "foreground": "#ebcc34",
          "template": "{{ .Context }}",
          "properties": {
            "parse_kubeconfig": true,
            "context_aliases": {
              "default/api-ocp-dev-byu-edu:6443/rbulkley@byu.edu": "ocp-dev",
              "default/api-ocp-byu-edu:6443/rbulkley@byu.edu": "ocp-prd",
              "default/api-osv-prd-byu-edu:6443/rbulkley@byu.edu": "osv-prd",
              "default/api-osv-byuh-edu:6443/rbulkley@byuh.edu": "osv-byuh"
            }
          }
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#8AA499",
          "options": {
            "style": "letter",
            "max_depth": 1
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#D0666F",
          "properties": {
            "branch_icon": ""
          },
          "template": "{{ .HEAD }}"
        },
        {
          "type": "jujutsu",
          "style": "plain",
          "foreground": "#FB542B",
          "template": "jj"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#BF616A",
          "template": " {{ .Code }}"
        }
      ],
      "type": "prompt"
    }
  ]
}
